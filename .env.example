# Required
TELEGRAM_BOT_TOKEN=123456:replace-me

# Strongly recommended: limit access to your own Telegram account/chat.
# Comma-separated numeric chat ids.
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional pi settings
PI_CWD=.
PI_AGENT_DIR=~/.pi/agent
PI_MODEL=
PI_THINKING_LEVEL=off
PI_TOOL_MODE=readonly

# Optional Telegram bot state directory
STATE_DIR=.data/telegram-pi

# Optional behavior
TELEGRAM_ALLOW_GROUPS=false
